# MongoDB URI; en la versión actual se espera que apunte a tu
# clúster de Atlas (Free Tier). Si alguna vez usas Docker Compose
# con Mongo local, entonces podrías usar mongodb://mongo:27017.
# Sustituye el valor a tu conveniencia:
#   MONGO_URI=mongodb+srv://usuario:password@cluster0.abcd.mongodb.net/test
MONGO_URI=mongodb://mongo:27017
# Si quieres una base externa reemplaza la URI arriba

# Registros totales de clientes/​productos/facturas (ambos si no hay valores separados)
SEED_N=200000
# Registros específicos (opcional):
# SEED_N_CLIENTES=100000
# SEED_N_PRODUCTOS=300000
# SEED_N_FACTURAS=50000

# Tamaño de cada lote insertado en Mongo (por ejemplo, 10000)
SEED_BATCH=10000
# Cantidad de workers paralelos para clients/productos (vale 1..N)
SEED_WORKERS=4

# --- Variables nuevas para el pipeline Kafka ---
# BROKERS separados por coma, e.g. "localhost:9092,localhost:9093"
# (si no se define se usa localhost:9092)
#KAFKA_BROKERS=localhost:9092

# Topic donde los producers publican y el consumer se suscribe:
#KAFKA_TOPIC=productos

# ID de grupo utilizado por el consumer (permite escalar consumidores):
#KAFKA_GROUP_ID=mongo-inserter

