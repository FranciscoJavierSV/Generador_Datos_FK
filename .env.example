# URI de MongoDB (en línea)
MONGO_URI=****


# Cantidad de registros a generar
SEED_N=100000

# Tamaño del batch durante generación de datos
SEED_BATCH=5000

# Tamaño del lote de inserción en MongoDB
CONSUMER_BATCH_SIZE=5000

# Cantidad de workers paralelos
SEED_WORKERS=4

# Kafka broker (host:puerto)
KAFKA_BROKERS=kafka:9092

# Topic de Kafka donde se publican los datos
KAFKA_TOPIC=data

# Kafka tamaño máximo de mensajes (100MB en bytes)
KAFKA_LOG_MESSAGE_MAX_BYTES=100485760
KAFKA_REPLICA_FETCH_MAX_BYTES=100485760

# Grupo de consumidores de Kafka
KAFKA_GROUP_ID=data-collector

# Directorio donde almacenar datos localmente (dentro del contenedor)
DATA_DIR=/app/data

# Puerto HTTP del consumer (expone API de datos)
METRICS_PORT=9464